{
    "name": "papdy/app",
    "description": "PHP Application Deployment",
    "keywords": [
        "php",
        "deployment"
    ],
    "homepage": "https://papdy.app",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Andreas Knollmann",
            "email": "a.knollmann@seak.dev"
        }
    ],
    "require": {
        "php": "^8.0",
        "fewedev/base": "^1.4",
        "laravel-zero/framework": "^12.0.2",
        "matomo/ini": "^3.0",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": [
        "papdy"
    ],
    "scripts": {
        "fix": "vendor/bin/php-cs-fixer fix app",
        "cs": "vendor/bin/php-cs-fixer fix app --dry-run --verbose --diff",
        "ps": "vendor/bin/phpstan analyse"
    }
}
